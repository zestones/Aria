[flake8]
exclude =
    venv,
    .venv,
    __pycache__,
    .git,
    env,
    .env,
    build,
    dist,
    *.egg-info,
    infrastructure/database/migrations

max-line-length = 100
max-complexity = 12

# E203 / W503: conflicts with black
# E501: line length is enforced by black
# F403/F405: allow star imports in __init__.py barrel files
ignore = E203,W503,E501,F403,F405

per-file-ignores =
    __init__.py:F401
    tests/*:S101
